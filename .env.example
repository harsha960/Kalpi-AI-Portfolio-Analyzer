# ---- Kalpi AI Portfolio Analyzer · environment template ----
# Copy to .env and fill in. The app runs WITHOUT a key (rule-based agent fallback).

# LLM agent (intent classification). Leave blank to use the rule-based fallback.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Market data / assumptions
BENCHMARK_TICKER=^NSEI        # Nifty 50
PRICE_HISTORY_PERIOD=2y       # yfinance period: 1y, 2y, 5y, max
RISK_FREE_RATE=0.065          # ~6.5% annual (India) for Sharpe ratio
